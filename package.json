{
  "name": "starter-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vue-tsc -b && vp build",
    "preview": "vp preview",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.434",
    "@types/node": "^25.2.0",
    "@unocss/reset": "^66.6.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "unocss": "^66.6.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vue-router": "^5.0.2",
    "vue-tsc": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher"
    ]
  }
}
